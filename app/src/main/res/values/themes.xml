<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.WolfClient" parent="Theme.AppCompat.NoActionBar">
        <item name="colorPrimary">@color/accent_gold</item>
        <item name="colorPrimaryDark">@color/bg_dark</item>
        <item name="colorAccent">@color/accent_gold</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_header</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>
    </style>

    <style name="Theme.WolfClient.ActionBar" parent="Theme.WolfClient">
        <item name="windowActionBar">true</item>
        <item name="windowNoTitle">false</item>
        <item name="actionBarStyle">@style/WolfActionBar</item>
    </style>

    <style name="WolfActionBar" parent="Widget.AppCompat.ActionBar">
        <item name="android:background">@color/bg_header</item>
        <item name="titleTextStyle">@style/WolfActionBarTitle</item>
    </style>

    <style name="WolfActionBarTitle" parent="TextAppearance.AppCompat.Widget.ActionBar.Title">
        <item name="android:textColor">@color/accent_gold</item>
    </style>
</resources>
