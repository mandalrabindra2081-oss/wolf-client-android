<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark"
    android:padding="0dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="180dp"
        android:orientation="vertical"
        android:gravity="center"
        android:background="@color/bg_header">

        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@drawable/ic_wolf"
            android:contentDescription="Wolf Client Logo" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="WOLF CLIENT"
            android:textColor="@color/accent_gold"
            android:textSize="26sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"
            android:layout_marginTop="10dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="v1.0.0  •  Minecraft Bedrock"
            android:textColor="@color/text_secondary"
            android:textSize="12sp"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- Status bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:background="@color/bg_card">

        <View
            android:id="@+id/overlayStatusDot"
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/dot_off" />

        <TextView
            android:id="@+id/overlayStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Overlay: OFF"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:layout_marginStart="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Wolf Client"
            android:textColor="@color/accent_gold"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="20dp"
        android:gravity="center">

        <!-- Launch MCPE -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnLaunchMcpe"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="▶  LAUNCH MINECRAFT"
            android:textColor="@color/bg_dark"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/btn_primary"
            android:layout_marginBottom="14dp" />

        <!-- Toggle Overlay -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnToggleOverlay"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Enable Overlay"
            android:textColor="@color/accent_gold"
            android:textSize="14sp"
            android:textStyle="bold"
            android:background="@drawable/btn_secondary"
            android:layout_marginBottom="14dp" />

        <!-- Settings -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnSettings"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="⚙  Settings"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:background="@drawable/btn_secondary"
            android:layout_marginBottom="14dp" />

        <!-- Discord -->
        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnDiscord"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Discord"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:background="@drawable/btn_ghost" />
    </LinearLayout>

    <!-- Footer -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:gravity="center"
        android:text="Wolf Client • Open Source"
        android:textColor="@color/text_secondary"
        android:textSize="11sp" />

</LinearLayout>
