<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="160dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/hud_bg"
    android:padding="10dp"
    android:elevation="10dp">

    <!-- HUD Title row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Wolf Client"
            android:textColor="@color/accent_gold"
            android:textSize="13sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btn_close_hud"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_close"
            android:contentDescription="Close" />
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginBottom="8dp" />

    <!-- Launch MC button -->
    <LinearLayout
        android:id="@+id/btn_launch_mc"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:background="@drawable/btn_hud"
        android:gravity="center"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="▶  Launch MC"
            android:textColor="@color/bg_dark"
            android:textSize="12sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Status labels -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tap W to close"
        android:textColor="@color/text_secondary"
        android:textSize="10sp"
        android:gravity="center"
        android:layout_marginTop="6dp" />

</LinearLayout>
